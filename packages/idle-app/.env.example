# Idle App — Environment Configuration
# Copy to .env and customize for your setup.
# Expo reads EXPO_PUBLIC_* vars at build time.

# --- Server URL ---
# Override to point at a local server (defaults to production)
# EXPO_PUBLIC_IDLE_SERVER_URL=http://localhost:3005

# --- Debug ---
# Enable debug logging in auth flow
# EXPO_PUBLIC_DEBUG=1

# --- App Environment Variant ---
# Controls app name and bundle ID, NOT server URL
# Values: development | preview | production
# APP_ENV=development

# --- Analytics (optional) ---
# EXPO_PUBLIC_POSTHOG_API_KEY=

# --- RevenueCat (optional, for subscriptions) ---
# EXPO_PUBLIC_REVENUE_CAT_APPLE=
# EXPO_PUBLIC_REVENUE_CAT_GOOGLE=
# EXPO_PUBLIC_REVENUE_CAT_STRIPE=
