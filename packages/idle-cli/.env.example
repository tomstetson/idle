# Idle CLI — Environment Configuration
# Copy to .env and customize for your setup.
# The CLI uses --env-file flag, not dotenv. See also .envrc.example for direnv users.

# Debug logging (set to 1 for verbose output)
DEBUG=1

# Suppress Node warnings
NODE_NO_WARNINGS=1

# --- Data Directory ---
# Separate dev directory to keep dev/prod auth apart
# IDLE_HOME_DIR=~/.idle-dev

# --- Server URLs ---
# Override to point at a local server (defaults to production)
# IDLE_SERVER_URL=http://localhost:3005
# IDLE_WEBAPP_URL=http://localhost:8081

# --- Variant ---
# Controls branding/naming (stable | dev)
# IDLE_VARIANT=dev

# --- Experimental Features ---
# IDLE_EXPERIMENTAL=true

# --- macOS Caffeinate ---
# Disable caffeinate keep-awake (enabled by default on macOS)
# IDLE_DISABLE_CAFFEINATE=true

# --- AI Debug Logging ---
# Send logs to server for AI-assisted debugging
# DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true
