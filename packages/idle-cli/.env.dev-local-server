IDLE_HOME_DIR=~/.idle-dev

# Local development server
IDLE_SERVER_URL=http://localhost:3005
IDLE_WEBAPP_URL=http://localhost:8081

DEBUG=1
# DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true

# We have this in bin too for production
NODE_NO_WARNINGS=1

