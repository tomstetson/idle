# Idle Server — Environment Configuration
# Copy to .env and customize for your setup.

# --- Database ---
# PGlite embedded (default) — no external PostgreSQL needed.
# For Postgres: DATABASE_URL=postgresql://user:pass@localhost:5432/idle
# When DATABASE_URL is unset, PGlite auto-creates in data/pglite/
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/idle

# Override PGlite/data storage paths (rarely needed)
# PGLITE_DIR=./data/pglite
# DATA_DIR=./data

# --- Server ---
PORT=3005
NODE_ENV=development

# Auth token signing secret (required)
IDLE_MASTER_SECRET=generate-a-random-secret-here

# Auth token TTL in days (default: 90)
# IDLE_TOKEN_TTL_DAYS=90

# --- Metrics ---
METRICS_ENABLED=true
METRICS_PORT=9090

# --- Debug Logging ---
# Writes consolidated logs to .logs/ for AI debugging
DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=false

# --- Local S3/MinIO (optional, for file storage) ---
# Without S3_HOST, files are stored locally in DATA_DIR
# S3_HOST=localhost
# S3_PORT=9000
# S3_USE_SSL=false
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=idle
# S3_PUBLIC_URL=http://localhost:9000/idle
# S3_REGION=us-east-1

# Public URL for file download links (defaults to http://localhost:PORT)
# PUBLIC_URL=https://idle-api.northglass.io

# --- Redis (optional, for multi-process event bus) ---
# Without REDIS_URL, event bus is process-local only
# REDIS_URL=redis://localhost:6379

# --- Voice (optional, ElevenLabs) ---
# ELEVENLABS_API_KEY=your-key-here

# --- GitHub App (optional, for GitHub integration) ---
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=
# GITHUB_WEBHOOK_SECRET=
